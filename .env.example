# Production tenant routing. Leave empty for single-domain mode.
# Example: NUXT_TENANT_BASE_DOMAIN=opendojo.example.com
NUXT_TENANT_BASE_DOMAIN=

# Public legal and customer-support details. Set these before production launch.
NUXT_PUBLIC_LEGAL_ENTITY_NAME=OpenDojo
NUXT_PUBLIC_SUPPORT_EMAIL=support@your-domain.com
NUXT_PUBLIC_SUPPORT_PHONE=
NUXT_PUBLIC_LEGAL_ADDRESS=

# Generate a strong 32+ character session secret for production.
NUXT_SESSION_PASSWORD=

# PostgreSQL connection string. Keep the real value in .env or your host's secret store.
# Example: DATABASE_URL=postgresql://postgres:password@localhost:5432/opendojo
DATABASE_URL=

# Development only. Never enable this in production.
NUXT_ENABLE_TEST_PLAN_CHANGES=false
