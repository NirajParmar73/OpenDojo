{
  "name": "fnv1a-64",
  "type": "module",
  "version": "0.1.1",
  "description": "Tiny, fast, dependency-free 64-bit FNV-1a string hash for Node and the browser",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "danielroe/fnv1a-64"
  },
  "keywords": [
    "fnv",
    "fnv1a",
    "fnv-1a",
    "hash",
    "64-bit",
    "non-cryptographic"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@sindresorhus/fnv1a": "^3.1.0",
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "fnv-lite": "^1.2.0",
    "fnv-plus": "^1.3.1",
    "installed-check": "10.0.1",
    "knip": "6.26.0",
    "mitata": "^1.0.34",
    "murmurhash": "^2.0.1",
    "nano-staged": "1.0.2",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.24.0",
    "simple-git-hooks": "2.13.1",
    "tsdown": "0.22.7",
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "xxhashjs": "^0.2.2"
  },
  "simple-git-hooks": {
    "pre-commit": "npx nano-staged"
  },
  "nano-staged": {
    "*.{js,ts,mjs,cjs,json,.*rc}": [
      "npx oxlint --type-aware --fix"
    ]
  },
  "scripts": {
    "build": "tsdown",
    "dev": "vitest dev",
    "lint": "oxlint --type-aware",
    "test": "pnpm test:unit && pnpm test:types",
    "test:unit": "vitest",
    "test:knip": "knip",
    "test:versions": "installed-check -d --no-workspaces",
    "bench": "node bench.mjs",
    "collisions": "node collisions.mjs",
    "test:types": "tsc --noEmit"
  }
}